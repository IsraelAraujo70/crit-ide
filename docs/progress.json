  "keybindings": {
    "Arrow Up/Down/Left/Right": "cursor movement (or tree nav when tree focused)",
    "Ctrl+Left / Ctrl+Right": "cursor.word_left / cursor.word_right",
    "Home / End": "cursor.home / cursor.end",
    "PageUp / PageDown": "scroll.up / scroll.down",
    "Enter": "insert.newline (with auto-indent; or tree.enter when tree focused)",
    "Backspace / Delete": "delete.backward / delete.forward",
    "Tab": "edit.indent (indent selection) / insert.char (tab when no selection)",
    "Shift+Tab": "edit.dedent (dedent selection)",
    "Ctrl+S": "file.save",
    "Ctrl+Q": "app.quit",
    "Ctrl+Z": "edit.undo",
    "Ctrl+Y": "edit.redo",
    "Ctrl+D": "edit.duplicate_line",
    "Ctrl+C / Ctrl+X / Ctrl+V": "clipboard.copy / cut / paste",
    "Ctrl+A": "select.all",
    "Ctrl+B": "tree.toggle",
    "Ctrl+W": "tab.close",
    "Ctrl+PageDown": "tab.next",
    "Ctrl+PageUp": "tab.prev",
    "Ctrl+K": "lsp.hover — show type info in statusline",
    "Ctrl+G": "goto.line — go to line number (opens prompt)",
    "F12": "lsp.definition — go to definition",
    "Ctrl+L": "lsp.format — format document",
    "a (tree focused)": "tree.new — create file/dir",
    "r (tree focused)": "tree.rename — rename at cursor",
    "d (tree focused)": "tree.delete — delete at cursor",
    "Backspace/Delete (tree focused)": "tree.delete",
    "Ctrl+F": "search.open — open Find bar (uses selection as query if active)",
    "F3": "search.next — find next match",
    "Shift+F3": "search.prev — find previous match",
    "Tab (in search)": "search.toggle_replace — toggle/switch replace field",
    "Enter (in search find)": "search.next — find next match",
    "Enter (in search replace)": "search.replace — replace current match",
    "Ctrl+A (in search)": "search.replace_all — replace all matches",
    "Ctrl+P": "finder.open — open fuzzy file finder",
    "Enter (in finder)": "finder.confirm — open selected file",
    "Up/Down (in finder)": "finder.up/down — navigate results",
    "Escape (in finder)": "finder.close — close finder",
    "Escape": "input.escape / tree.focus.editor / prompt.cancel / search.close / finder.close",
    "Left click": "mouse.click / tab.click / tree.click (auto-routed by position)",
    "Double click": "select.word — select word under cursor",
    "Left drag": "mouse.drag",
    "Right click": "menu.open",
    "Wheel Up/Down": "mouse.scroll (editor or tree, auto-routed)",
    "Ctrl+Space": "completion.trigger — manual completion trigger",
    "Enter/Tab (in completion)": "completion.accept — insert selected completion",
    "Up/Down (in completion)": "completion.up/down — navigate completion items",
    "Escape (in completion)": "completion.dismiss — close completion popup",
    ". (auto-trigger)": "completion auto-trigger on LSP trigger characters",
    "F1 / Ctrl+Shift+P": "palette.open — open command palette",
    "Enter (in palette)": "palette.execute — execute selected command",
    "Up/Down (in palette)": "palette.up/down — navigate commands",
    "Escape (in palette)": "palette.close — close command palette",
    "Ctrl+Shift+F / F5": "project.search — open project-wide search",
    "Enter (in project search, no results)": "project.search_execute — run search",
    "Enter (in project search, on result)": "project.search_open_result — open file at match",
    "Up/Down (in project search)": "project.search_up/down — navigate results",
    "F3 (in project search)": "project.search_next — jump to next match result",
    "Escape (in project search)": "project.search_close — close project search",
    "F2": "lsp.rename — rename symbol under cursor",
    "Ctrl+.": "lsp.code_action — show available code actions",
    "( (auto-trigger)": "signature help auto-trigger on function call open paren",
    "Up/Down (in code actions)": "code_action.up/down — navigate code action items",
    "Enter (in code actions)": "code_action.execute — apply selected code action",
    "Escape (in code actions)": "code_action.dismiss — close code actions popup",
    "Ctrl+`": "terminal.toggle — toggle embedded terminal panel",
    "Ctrl+Shift+`": "terminal.new — open new terminal session",
    "All keys (terminal focused)": "sent to PTY (except Ctrl+` for toggle)",
    "Ctrl+C (terminal focused)": "SIGINT to terminal process"
