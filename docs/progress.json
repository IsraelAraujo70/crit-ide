{
  "project": "crit-ide",
  "version": "0.2.0-dev",
  "phases": [
    {
      "name": "Foundation",
      "status": "done",
      "summary": "Core event-driven architecture, single-buffer editing, tcell rendering",
      "deliverables": [
        { "item": "Go project scaffolding (go.mod, .gitignore, directory structure)", "status": "done" },
        { "item": "TextStore interface with LineStore ([]string) implementation", "status": "done" },
        { "item": "Buffer with cursor movement, Unicode-aware insert/delete, sticky column", "status": "done" },
        { "item": "Non-blocking event bus (channel-based)", "status": "done" },
        { "item": "Action interface, Registry, and concrete actions", "status": "done" },
        { "item": "Input handler goroutine with hardcoded keymap", "status": "done" },
        { "item": "tcell renderer with line numbers, cursor, statusline", "status": "done" },
        { "item": "Main event loop (App.Run) serializing all state mutations", "status": "done" },
        { "item": "File open and save", "status": "done" }
      ]
    },
    {
      "name": "Mouse & Selection",
      "status": "done",
      "summary": "Full mouse support, text selection, clipboard, context menu",
      "deliverables": [
        { "item": "Mouse click to position cursor", "status": "done" },
        { "item": "Mouse scroll for viewport", "status": "done" },
        { "item": "Mouse drag to select text", "status": "done" },
        { "item": "Selection rendering with highlight", "status": "done" },
        { "item": "Selection-aware mutations (typing/delete replaces selection)", "status": "done" },
        { "item": "System clipboard (Ctrl+C/X/V) via atotto/clipboard", "status": "done" },
        { "item": "Select All (Ctrl+A)", "status": "done" },
        { "item": "Right-click context menu (Copy/Cut/Paste/Select All)", "status": "done" },
        { "item": "Modal input routing for context menu", "status": "done" },
        { "item": "Popup rendering with borders and keyboard navigation", "status": "done" },
        { "item": "Double-click to select word", "status": "done" }
      ]
    },
    {
      "name": "Multi-buffer & Tabs",
      "status": "done",
      "summary": "Multi-buffer tab system with tab bar UI",
      "deliverables": [
        { "item": "Multi-buffer management (open, close, switch)", "status": "done" },
        { "item": "Tab bar rendering with active indicator and dirty flag", "status": "done" },
        { "item": "Tab click to switch, close button on tabs", "status": "done" },
        { "item": "Ctrl+PgDn/PgUp for tab navigation", "status": "done" },
        { "item": "Ctrl+W to close tab", "status": "done" },
        { "item": "Per-buffer scroll position preservation", "status": "done" },
        { "item": "Open file from tree into new tab (or switch to existing)", "status": "done" }
      ]
    },
    {
      "name": "File Tree (NeoTree)",
      "status": "done",
      "summary": "File explorer panel on the right side with keyboard and mouse navigation",
      "deliverables": [
        { "item": "FileTree package with Node/tree state management", "status": "done" },
        { "item": "Directory reading, sorting (dirs first), hidden file filtering", "status": "done" },
        { "item": "Tree rendering with icons, indentation, and cursor highlight", "status": "done" },
        { "item": "Keyboard navigation (arrows, Enter, Escape)", "status": "done" },
        { "item": "Expand/collapse directories", "status": "done" },
        { "item": "Click on tree to open file or toggle directory", "status": "done" },
        { "item": "Ctrl+B to toggle tree visibility", "status": "done" },
        { "item": "Mouse scroll in tree panel", "status": "done" },
        { "item": "Focus routing between editor and tree", "status": "done" },
        { "item": "Tree refresh preserving expanded state", "status": "done" },
        { "item": "Create file/directory from tree (a key, end with / for dir)", "status": "done" },
        { "item": "Rename file/directory from tree (r key)", "status": "done" },
        { "item": "Delete file/directory from tree (d key, with confirmation)", "status": "done" },
        { "item": "Input prompt system (ModePrompt) with cursor, backspace, navigation", "status": "done" },
        { "item": "Nested path creation (pkg/models/user.go creates intermediate dirs)", "status": "done" }
      ]
    },
    {
      "name": "Syntax Highlighting",
      "status": "done",
      "summary": "Tree-sitter based syntax highlighting with 14 language support",
      "deliverables": [
        { "item": "Tree-sitter integration via go-tree-sitter", "status": "done" },
        { "item": "TSLangRegistry with language detection by file extension", "status": "done" },
        { "item": "Highlighter interface (HighlightLine returns tokens)", "status": "done" },
        { "item": "Token-to-theme style mapping", "status": "done" },
        { "item": "14 languages: Go, Python, JavaScript, TypeScript, Rust, C, CSS, HTML, JSON, Markdown, TOML, YAML, Bash", "status": "done" },
        { "item": "Incremental reparse on content change (SetSource)", "status": "done" },
        { "item": "Per-buffer language switching on tab change", "status": "done" }
      ]
    },
    {
      "name": "LSP Integration",
      "status": "done",
      "summary": "Language Server Protocol client with diagnostics, hover, go-to-definition, and formatting",
      "deliverables": [
        { "item": "LSP client (stdio JSON-RPC)", "status": "done" },
        { "item": "LSP Manager (multi-language server lifecycle)", "status": "done" },
        { "item": "Diagnostics (inline underline rendering with severity colors)", "status": "done" },
        { "item": "Go to definition (Ctrl+G / F12)", "status": "done" },
        { "item": "Hover information (Ctrl+K → statusline)", "status": "done" },
        { "item": "Format document (Ctrl+L)", "status": "done" },
        { "item": "didOpen / didChange / didSave / didClose notifications", "status": "done" },
        { "item": "LSP position ↔ editor byte offset conversion", "status": "done" },
        { "item": "Error/warning count in statusline", "status": "done" },
        { "item": "Autocomplete (Ctrl+Space / auto-trigger on trigger chars)", "status": "done" },
        { "item": "Completion popup with kind icons, detail, scroll, prefix filtering", "status": "done" },
        { "item": "ModeCompletion input routing (Up/Down/Enter/Tab/Escape/typing)", "status": "done" },
        { "item": "Rename Symbol (F2) — prompt with pre-filled symbol name, LSP textDocument/rename, WorkspaceEdit across files", "status": "done" },
        { "item": "Code Actions (Ctrl+.) — textDocument/codeAction, popup with action list, apply WorkspaceEdit", "status": "done" },
        { "item": "Signature Help — auto-trigger on (, textDocument/signatureHelp, active parameter highlight", "status": "done" }
      ]
    },
    {
      "name": "Editing Essentials",
      "status": "done",
      "summary": "Undo/redo, word movement, auto-indent, duplicate line, and word selection",
      "deliverables": [
        { "item": "Undo/redo system with UndoStack (Ctrl+Z / Ctrl+Y)", "status": "done" },
        { "item": "Word movement (Ctrl+Left / Ctrl+Right)", "status": "done" },
        { "item": "Duplicate line (Ctrl+D)", "status": "done" },
        { "item": "Auto-indent on Enter (copies leading whitespace)", "status": "done" },
        { "item": "Double-click word selection", "status": "done" },
        { "item": "SelectWord action for programmatic word selection", "status": "done" },
        { "item": "Block indent/dedent selection (Tab/Shift+Tab)", "status": "done" },
        { "item": "Find/Replace (Ctrl+F) with match highlighting, next/prev, replace one/all", "status": "done" },
        { "item": "Fuzzy File Finder (Ctrl+P) — Telescope-style popup, score-based fuzzy matching, .gitignore, file cache", "status": "done" },
        { "item": "Project-wide Search (Ctrl+Shift+F / F5) — grep/ripgrep search, results grouped by file, navigate to match", "status": "done" }
      ]
    },
    {
      "name": "Minimap",
      "status": "done",
      "summary": "Code minimap with viewport indicator, diagnostic markers, and click-to-scroll",
      "deliverables": [
        { "item": "Minimap column (12 chars) rendering compacted code preview", "status": "done" },
        { "item": "Half-block Unicode chars for compact display", "status": "done" },
        { "item": "Syntax-highlighted colors (dimmed) from tree-sitter tokens", "status": "done" },
        { "item": "Viewport indicator (highlighted region showing visible area)", "status": "done" },
        { "item": "Diagnostic markers (red=error, yellow=warning) in gutter", "status": "done" },
        { "item": "Search match markers (orange) in gutter", "status": "done" },
        { "item": "Cursor line marker (white) in gutter", "status": "done" },
        { "item": "Click on minimap to scroll to position", "status": "done" },
        { "item": "Scroll on minimap scrolls editor", "status": "done" },
        { "item": "Toggle minimap with Ctrl+Shift+M", "status": "done" },
        { "item": "Command palette entry for minimap toggle", "status": "done" },
        { "item": "Auto-scaling: adapts lines-per-row to fit entire file", "status": "done" }
      ]
    },
    {
      "name": "Splits",
      "status": "planned",
      "summary": "Horizontal/vertical splits with multiple views per buffer",
      "deliverables": [
        { "item": "EditorView decoupled from Buffer (multiple views per buffer)", "status": "planned" },
        { "item": "LayoutTree with horizontal/vertical splits", "status": "planned" },
        { "item": "Split resize via keyboard", "status": "planned" },
        { "item": "Mouse click to focus pane", "status": "planned" },
        { "item": "Enhanced statusline with per-pane info", "status": "planned" }
      ]
    },
    {
      "name": "Commands & Keymaps",
      "status": "planned",
      "summary": "Command registry, configurable keymap engine, command palette, fuzzy file open",
      "deliverables": [
        { "item": "CommandRegistry with ID-based commands", "status": "planned" },
        { "item": "Configurable keymap engine (TOML-based)", "status": "planned" },
        { "item": "Context-aware keybinding resolution", "status": "planned" },
        { "item": "Chord/leader key support", "status": "planned" },
        { "item": "Command palette popup (F1 / Ctrl+Shift+P) — centered popup with fuzzy filter, category grouping, keybinding display", "status": "done" },
        { "item": "Fuzzy file finder", "status": "done" }
      ]
    },
    {
      "name": "Git",
      "status": "done",
      "summary": "Git integration with status panel, graph, diff viewer, and gutter indicators",
      "deliverables": [
        { "item": "Git status panel (staged, unstaged, untracked) — Ctrl+Shift+G toggle, s:stage/unstage, d:diff, c:commit, Enter:open", "status": "done" },
        { "item": "Diff viewer (inline unified diff with color-coded +/- lines)", "status": "done" },
        { "item": "Stage/unstage file from status panel", "status": "done" },
        { "item": "Basic commit from IDE (prompt for commit message)", "status": "done" },
        { "item": "Branch display in statusline", "status": "done" },
        { "item": "Git graph (F6) — visual log with branch colors, scroll navigation", "status": "done" },
        { "item": "Gutter indicators (green:added, yellow:modified, red:deleted)", "status": "done" },
        { "item": "FocusGitPanel in focus system", "status": "done" },
        { "item": "Git output parsing tests", "status": "done" }
      ]
    },
    {
      "name": "Terminal & Tasks",
      "status": "in-progress",
      "summary": "Embedded terminal pane with PTY, multiple sessions, ANSI color rendering",
      "deliverables": [
        { "item": "Terminal pane with PTY integration (creack/pty)", "status": "done" },
        { "item": "Multiple terminal sessions with tab bar", "status": "done" },
        { "item": "ANSI escape code parsing (colors, bold, italic, 256-color, truecolor)", "status": "done" },
        { "item": "Input routing: all keys to PTY when terminal focused (except Ctrl+`)", "status": "done" },
        { "item": "Ctrl+` toggle, Ctrl+Shift+` new session", "status": "done" },
        { "item": "Ctrl+C sends SIGINT to terminal process", "status": "done" },
        { "item": "Terminal panel rendering at bottom (1/3 height)", "status": "done" },
        { "item": "Actions: terminal.toggle, terminal.new, terminal.close, terminal.next", "status": "done" },
        { "item": "PTY creation and ANSI parsing tests (19 tests)", "status": "done" },
        { "item": "Task runner (build, test, lint)", "status": "planned" },
        { "item": "Problem matcher (click error → go to file:line)", "status": "planned" }
      ]
    },
    {
      "name": "AI Integration",
      "status": "planned",
      "summary": "Local AI autocomplete and code assistance",
      "deliverables": [
        { "item": "AI provider abstraction (Ollama first)", "status": "planned" },
        { "item": "Inline ghost text completion", "status": "planned" },
        { "item": "Explain selection action", "status": "planned" },
        { "item": "Context builder (current file, imports, LSP symbols)", "status": "planned" },
        { "item": "Hot-reloadable TOML configuration", "status": "planned" }
      ]
    }
  ],
