{
  "project": "crit-ide",
  "version": "0.1.0-dev",
  "sprints": [
    {
      "id": 1,
      "name": "Foundation",
      "status": "done",
      "completed_at": "2026-04-04",
      "summary": "Core event-driven architecture, single-buffer editing, tcell rendering",
      "deliverables": [
        {
          "item": "Go project scaffolding (go.mod, .gitignore, directory structure)",
          "status": "done"
        },
        {
          "item": "TextStore interface with LineStore ([]string) implementation",
          "status": "done"
        },
        {
          "item": "Buffer with cursor movement, Unicode-aware insert/delete, sticky column",
          "status": "done"
        },
        {
          "item": "Non-blocking event bus (channel-based)",
          "status": "done"
        },
        {
          "item": "Action interface, Registry, and 14 concrete actions",
          "status": "done"
        },
        {
          "item": "Input handler goroutine with hardcoded keymap",
          "status": "done"
        },
        {
          "item": "tcell renderer with line numbers, cursor, statusline",
          "status": "done"
        },
        {
          "item": "Main event loop (App.Run) serializing all state mutations",
          "status": "done"
        },
        {
          "item": "File open and save",
          "status": "done"
        },
        {
          "item": "42 unit tests covering editor core and actions",
          "status": "done"
        }
      ],
      "actions_registered": [
        "cursor.up",
        "cursor.down",
        "cursor.left",
        "cursor.right",
        "cursor.home",
        "cursor.end",
        "insert.char",
        "insert.newline",
        "delete.backward",
        "delete.forward",
        "file.save",
        "app.quit",
        "scroll.up",
        "scroll.down"
      ],
      "keybindings": {
        "Arrow Up": "cursor.up",
        "Arrow Down": "cursor.down",
        "Arrow Left": "cursor.left",
        "Arrow Right": "cursor.right",
        "Home": "cursor.home",
        "End": "cursor.end",
        "Enter": "insert.newline",
        "Backspace": "delete.backward",
        "Delete": "delete.forward",
        "Tab": "insert.char (tab)",
        "Ctrl+S": "file.save",
        "Ctrl+Q": "app.quit",
        "PageUp": "scroll.up",
        "PageDown": "scroll.down",
        "Any printable key": "insert.char"
      }
    },
